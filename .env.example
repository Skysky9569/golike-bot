# environment variables for GoLike bot

# Telegram notification settings
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Golike credentials (used when password field is ${GOLIKE_PASSWORD})
GOLIKE_PASSWORD=your_golike_password

# Facebook credentials (optional - use for individual profiles)
GOLIKE_PASSWORD_1=your_password_for_profile_1
GOLIKE_PASSWORD_2=your_password_for_profile_2